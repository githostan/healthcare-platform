

# =============================================================================
# Example environment configuration for patient-service
# =============================================================================
# Purpose:
# - Provides a template of all environment variables required for the
#   patient-service to start and operate correctly.
# - Intended for developers to copy into a local `.env` file and populate with
#   real values. This file should NOT contain secrets and must remain safe to
#   commit to version control.
# - Production deployments must supply real values via secure environment
#   variables or secret management systems; `.env` files are for local
#   development only.
#
# - Each variable below includes a placeholder value that should be replaced
#   when creating a real `.env`.
# =============================================================================

PATIENT_SERVICE_API_KEY=changeme
ENVIRONMENT=dev
LOG_LEVEL=INFO
ENABLE_SEED_DATA=true
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
RATE_LIMIT_PER_MINUTE=60
